# ============================================================
# telemed-backend — environment template
# Copy to .env and fill in local values. .env is gitignored.
# ============================================================

# ── Database ────────────────────────────────────────────────
# Required. Prisma fails fast if invalid.
DATABASE_URL="mysql://root:password@localhost:3306/telemed-health"

# ── App ─────────────────────────────────────────────────────
PORT=3001
APP_URL=http://localhost:3001
NODE_ENV=development

# ── Auth secrets (REQUIRED) ─────────────────────────────────
# These sign JWTs. Use a 32+ char random string per secret.
# Quick generator: `openssl rand -base64 32`
# ADMIN_AUTH_SECRET and CUSTOMER_AUTH_SECRET are read via
# ConfigService.getOrThrow — the app will not boot without them.
JWT_SECRET=change-me-jwt-secret
ADMIN_AUTH_SECRET=change-me-admin-secret
CUSTOMER_AUTH_SECRET=change-me-customer-secret

# ── JWT lifetimes (optional, all in seconds) ────────────────
ADMIN_ACCESS_TOKEN_TTL_SECONDS=900
ADMIN_REFRESH_TOKEN_TTL_SECONDS=86400
ADMIN_REMEMBER_REFRESH_TOKEN_TTL_SECONDS=604800
ADMIN_TWO_FACTOR_TTL_SECONDS=600
CUSTOMER_ACCESS_TOKEN_TTL_SECONDS=900
CUSTOMER_REFRESH_TOKEN_TTL_SECONDS=86400
CUSTOMER_REMEMBER_REFRESH_TOKEN_TTL_SECONDS=604800
CUSTOMER_RESET_PASSWORD_TTL_SECONDS=3600

# ── At-rest encryption for stored provider creds ────────────
# Optional locally (creds stored as plaintext if unset).
# REQUIRED in production. 32-byte key, optionally `base64:`-prefixed.
# APP_KEY is recognized as a legacy alias.
CONFIG_ENCRYPTION_KEY=

# ── Doctor network polling ──────────────────────────────────
# How often the doctor-network token refresher runs. Default 15 min.
DOCTOR_NETWORK_REFRESH_INTERVAL_MS=900000

# ── Feature flags ───────────────────────────────────────────
# When "true", skips the CRM partial-order step at checkout.
# Useful for local dev when no CRM is configured.
BYPASS_CRM_CHECKOUT=false

# ── Provider env overrides (optional) ───────────────────────
# Most provider creds live in the DB (via /api/settings/*).
# These env vars are fallback overrides for local testing.

# VRIO CRM — legacy VIRO_* aliases also recognized in code.
VRIO_API_KEY=
VRIO_CONNECTION_ID=

# Generic CRM (used when env-driven CRM is wired)
CRM_API_KEY=
CRM_CONNECTION_ID=
CRM_ID=

# MD Integrations (doctor network)
MD_INTEGRATION_CLIENT_ID=
MD_INTEGRATION_CLIENT_SECRET=
MD_INTEGRATION_GRANT_TYPE=client_credentials
MD_INTEGRATION_SCOPE=

# ── Seed overrides ──────────────────────────────────────────
# Consumed by `npm run prisma:seed`. Defaults shown.
SEED_ADMIN_NAME=Local Super Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin@123456
