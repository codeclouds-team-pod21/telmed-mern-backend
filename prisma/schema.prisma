  dateDeliver                String?   @map("date_deliver") @db.VarChar(255)
  createdAt                  DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt                  DateTime? @map("updated_at") @db.Timestamp(0)
  deletedAt                  DateTime? @map("deleted_at") @db.Timestamp(0)
  order                      Order     @relation(fields: [orderId], references: [id], map: "order_transactions_order_id_foreign")

  @@index([orderId], map: "order_transactions_order_id_foreign")
  @@map("order_transactions")
}

model User {
  id                  Int                        @id @default(autoincrement())
  name                String                     @db.VarChar(255)
  email               String                     @unique @db.VarChar(255)
  emailVerifiedAt     DateTime?                  @map("email_verified_at") @db.Timestamp(0)
  password            String                     @db.VarChar(255)
  rememberToken       String?                    @map("remember_token") @db.VarChar(100)
  twoFactorCode       String?                    @map("two_factor_code") @db.VarChar(255)
  twoFactorEnabled    Boolean                    @map("two_factor_enabled") @default(true)
  twoFactorExpiresAt  DateTime?                  @map("two_factor_expires_at") @db.DateTime(0)
  phoneNumber         String?                    @map("phone_number") @db.VarChar(255)
  status              Boolean                    @default(true)
  lastLoggedIn        DateTime?                  @map("last_logged_in") @db.Timestamp(0)
  isDefault           Boolean                    @map("is_default") @default(false)
  createdAt           DateTime?                  @map("created_at") @db.Timestamp(0)
  updatedAt           DateTime?                  @map("updated_at") @db.Timestamp(0)
  deletedAt           DateTime?                  @map("deleted_at") @db.Timestamp(0)
  adminAssignments    AdminUserRolesPermission[]

  @@map("users")
}

model AdminRole {
  id              Int                        @id @default(autoincrement())
  name            String                     @db.VarChar(255)
  description     String?                    @db.VarChar(255)
  status          String                     @db.VarChar(1)
  isDefault       Boolean                    @map("is_default") @default(false)
  createdAt       DateTime?                  @map("created_at") @db.Timestamp(0)
  updatedAt       DateTime?                  @map("updated_at") @db.Timestamp(0)
  rolePermissions AdminRolePermission[]
  userAssignments AdminUserRolesPermission[]

  @@map("admin_roles")
}

model AdminPermission {
  id              Int                        @id @default(autoincrement())
  module          String                     @db.VarChar(255)
  scope           String                     @db.VarChar(255)
  action          String                     @db.VarChar(255)
  status          String                     @db.VarChar(255)
  actionRef       AdminAction                @relation(fields: [action], references: [name], map: "admin_permissions_action_foreign")
  rolePermissions AdminRolePermission[]
  userAssignments AdminUserRolesPermission[]

  @@unique([module, scope, action], map: "admin_permissions_module_scope_action_unique")
  @@map("admin_permissions")
}

model AdminAction {
  id                        Int               @id @default(autoincrement())
  name                      String            @unique @db.VarChar(255)
  label                     String            @db.VarChar(255)
  frameworkPermissionMapper String?           @map("framework_permission_mapper") @db.Text
  createdAt                 DateTime?         @map("created_at") @db.Timestamp(0)
  permissions               AdminPermission[]

  @@map("admin_actions")
}

model AdminRolePermission {
  id           Int             @id @default(autoincrement())
  roleId       Int             @map("role_id")
  permissionId Int             @map("permission_id")
  updatedAt    DateTime        @map("updated_at") @db.Timestamp(0)
  role         AdminRole       @relation(fields: [roleId], references: [id], map: "admin_role_permissions_role_id_foreign")
  permission   AdminPermission @relation(fields: [permissionId], references: [id], map: "admin_role_permissions_permission_id_foreign")

  @@unique([roleId, permissionId])
  @@map("admin_role_permissions")
}

model AdminUserRolesPermission {
  id           Int              @id @default(autoincrement())
  userId       Int              @map("user_id")
  roleId       Int?             @map("role_id")
  permissionId Int?             @map("permission_id")
  user         User             @relation(fields: [userId], references: [id], map: "admin_user_roles_permissions_user_id_foreign")
  role         AdminRole?       @relation(fields: [roleId], references: [id], map: "admin_user_roles_permissions_role_id_foreign")
  permission   AdminPermission? @relation(fields: [permissionId], references: [id], map: "admin_user_roles_permissions_permission_id_foreign")

  @@index([permissionId])
  @@index([roleId])
  @@map("admin_user_roles_permissions")
}
