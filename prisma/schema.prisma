generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum ProductClassification {
  main
  upsell
  supply
  titration
  lab
}

enum ProductGender {
  male
  female
  both
}

enum RedirectType {
  soft
  hard
}

enum FunnelStep {
  landing
  general_question
  account
  medical_question
  login
  notification
  register
  payment
  checkout
  identity_upload
  video_upload
  dashboard
}

enum OrderStatus {
  active
  cancelled
  complete
  partial
  declined
  archive
  rejected
  removed
  paused
  expired
  swapped
}

enum CrmOrderStatus {
  authorized
  captured
}

enum RelatedItemType {
  supply
  titration
}

enum QuestionnaireType {
  general
  medical
  swap
  vitals
}

enum AddressType {
  billing
  shipping
}

enum DocumentType {
  ID
  VIDEO
  OTHERS
}

enum SupportServiceType {
  zendesk
}

enum CrmType {
  vrio
  checkoutchamp
}

enum DoctorNetworkType {
  mdi
}

enum CustomerGender {
  male
  female
  other
}

model Crm {
  id               Int            @id @default(autoincrement())
  name             String         @db.VarChar(200)
  credentials      String         @db.LongText
  type             CrmType        @default(vrio)
  status           Boolean        @default(true)
  createdAt        DateTime?      @map("created_at") @db.Timestamp(0)
  updatedAt        DateTime?      @map("updated_at") @db.Timestamp(0)
  campaigns        CrmCampaign[]
  offers           CrmOffer[]
  shippingProfiles CrmShipping[]
  orders           Order[]
  customers        CrmCustomer[]

  @@map("crms")
}

model CrmCampaign {
  id               Int            @id @default(autoincrement())
  crmId            Int            @map("crm_id")
  campaignId       String         @map("campaign_id") @db.VarChar(255)
  name             String         @db.VarChar(255)
  createdAt        DateTime?      @map("created_at") @db.Timestamp(0)
  updatedAt        DateTime?      @map("updated_at") @db.Timestamp(0)
  status           Boolean        @default(true)
  crm              Crm            @relation(fields: [crmId], references: [id], map: "crm_campaign_crm_id_fk")
  offers           CrmOffer[]
  shippingProfiles CrmShipping[]
  funnels          Funnel[]       @relation("FunnelCampaign")
  renewalFunnels   Funnel[]       @relation("FunnelRenewalCampaign")
  swappableFunnels Funnel[]       @relation("FunnelSwappableCampaign")
  products         Product[]      @relation("ProductSwappableCampaign")
  renewalProducts  Product[]      @relation("ProductRenewalCampaign")
  funnelProducts   FunnelProduct[]
  productVariants  ProductVariant[]
  planVariantPrices PlanVariantPrice[]

  @@index([crmId], map: "crm_campaign_crm_id_fk")
  @@map("crm_campaigns")
}

model CrmOffer {
  id              Int              @id @default(autoincrement())
  offerId         String           @map("offer_id") @db.VarChar(255)
  crmId           Int              @map("crm_id")
  crmCampaignId   Int              @map("crm_campaign_id")
  name            String           @db.VarChar(255)
  createdAt       DateTime?        @map("created_at") @db.Timestamp(0)
  updatedAt       DateTime?        @map("updated_at") @db.Timestamp(0)
  status          Boolean          @default(true)
  crm             Crm              @relation(fields: [crmId], references: [id], map: "crm_offers_crm_id_fk")
  crmCampaign     CrmCampaign      @relation(fields: [crmCampaignId], references: [id], map: "crm_offers_crm_campaign_id_fk")
  productVariants ProductVariant[]
  planVariantPrices PlanVariantPrice[]
  coupons         CrmCoupon[]

  @@index([crmCampaignId], map: "crm_offers_crm_campaign_id_fk")
  @@index([crmId], map: "crm_offers_crm_id_fk")
  @@map("crm_offers")
}

model CrmShipping {
  id                Int              @id @default(autoincrement())
  crmId             Int              @map("crm_id")
  shippingProfileId Int              @map("shipping_profile_id")
  crmCampaignId     Int              @map("crm_campaign_id")
  shippingProfile   String           @map("shipping_profile") @db.VarChar(100)
  shippingPrice     Decimal          @map("shipping_price") @default(0.00) @db.Decimal(10, 2)
  createdAt         DateTime?        @map("created_at") @db.Timestamp(0)
  updatedAt         DateTime?        @map("updated_at") @db.Timestamp(0)
  crm               Crm              @relation(fields: [crmId], references: [id], map: "crm_shipping_crm_id_foreign")
  crmCampaign       CrmCampaign      @relation(fields: [crmCampaignId], references: [id], map: "crm_shipping_crm_campaign_id_fk")
  productVariants   ProductVariant[]
  planVariantPrices PlanVariantPrice[]

  @@index([crmCampaignId], map: "crm_shipping_crm_campaign_id_fk")
  @@index([crmId], map: "crm_shipping_crm_id_foreign")
  @@map("crm_shipping")
}

model DoctorNetwork {
  id               Int                  @id @default(autoincrement())
  name             String               @db.VarChar(255)
  apiUrl           String               @map("api_url") @db.VarChar(255)
  apiVersion       String?              @map("api_version") @db.VarChar(255)
  credentials      String               @db.LongText
  type             DoctorNetworkType    @default(mdi)
  introVideoStates String               @map("intro_video_states") @db.LongText
  createdAt        DateTime?            @map("created_at") @db.Timestamp(0)
  updatedAt        DateTime?            @map("updated_at") @db.Timestamp(0)
  status           Boolean              @default(true)
  offers           DoctorNetworkOffer[]
  productVariants  ProductVariant[]
  customers        Customer[]
  patients         Patient[]
  documents        Document[]
  tokens           DoctorNetworkToken[]
  questionnaires   Questionnaire[]

  @@map("doctor_networks")
}

model DoctorNetworkOffer {
  id                   Int            @id @default(autoincrement())
  doctorNetworkId      Int            @map("doctor_network_id")
  offerableId          String?        @map("offerable_id") @db.VarChar(255)
  name                 String?        @db.VarChar(255)
  metaData             String?        @map("meta_data") @db.VarChar(255)
  quantity             Int            @default(0)
  daysOfSupply         Int            @map("days_of_supply") @default(0)
  dispenseUnit         String?        @map("dispense_unit") @db.VarChar(255)
  refills              Int            @default(0)
  prescriptionDuration Int            @map("prescription_duration") @default(0)
  pharmacy             String?        @db.VarChar(255)
  createdAt            DateTime?      @map("created_at") @db.Timestamp(0)
  updatedAt            DateTime?      @map("updated_at") @db.Timestamp(0)
  doctorNetwork        DoctorNetwork  @relation(fields: [doctorNetworkId], references: [id], map: "doctor_network_offers_doctor_network_id_foreign")

  @@index([doctorNetworkId], map: "doctor_network_offers_doctor_network_id_foreign")
  @@map("doctor_network_offers")
}

model Questionnaire {
  id                     Int               @id @default(autoincrement())
  partnerQuestionnaireId String?           @map("partner_questionnaire_id") @db.VarChar(50)
  name                   String?           @db.VarChar(255)
  questions              String            @db.LongText
  doctorNetworkId        Int?              @map("doctor_network_id")
  intakeEngineType       String?           @map("intake_engine_type") @db.VarChar(20)
  offerings              Json?
  type                   QuestionnaireType
  status                 Boolean           @default(true)
  createdAt              DateTime?         @map("created_at") @db.Timestamp(0)
  updatedAt              DateTime?         @map("updated_at") @db.Timestamp(0)
  createdBy              Int?              @map("created_by")
  updatedBy              Int?              @map("updated_by")
  deletedBy              Int?              @map("deleted_by")
  deletedAt              DateTime?         @map("deleted_at") @db.Timestamp(0)
  doctorNetwork          DoctorNetwork?    @relation(fields: [doctorNetworkId], references: [id], map: "questionnaires_doctor_network_id_foreign")
  generalProducts        Product[]         @relation("ProductGeneralQuestion")
  medicalProducts        Product[]         @relation("ProductMedicalQuestion")
  changeMedicineProducts Product[]         @relation("ProductChangeMedicineQuestion")
  answers                Answer[]

  @@index([doctorNetworkId], map: "questionnaires_doctor_network_id_foreign")
  @@index([partnerQuestionnaireId], map: "questionnaires_partner_questionnaire_id_index")
  @@index([status], map: "questionnaires_status_index")
  @@index([type], map: "questionnaires_type_index")
  @@map("questionnaires")
}

model Product {
  id                       Int                   @id @default(autoincrement())
  name                     String                @db.VarChar(255)
  description              String?               @db.Text
  keypoints                String?               @db.LongText
  productGroupName         String?               @map("product_group_name") @db.VarChar(255)
  productSlugName          String?               @map("product_slug_name") @unique(map: "products_product_slug_name_unique") @db.VarChar(255)
  metaData                 String?               @map("meta_data") @db.VarChar(255)
  productCategory          String?               @map("product_category") @db.VarChar(255)
  productType              String?               @map("product_type") @db.VarChar(255)
  productClassification    ProductClassification @map("product_classification") @default(main)
  isUpsell                 Boolean               @map("is_upsell") @default(false)
  image                    String?               @db.LongText
  restrictedState          String?               @map("restricted_state") @db.LongText
  blockMilitaryBases       Boolean               @map("block_military_bases") @default(false)
  blockIslands             Boolean               @map("block_islands") @default(false)
  displayPrice             Decimal               @map("display_price") @default(0.00) @db.Decimal(10, 2)
  genericQuestionId        Int?                  @map("generic_question")
  medicalQuestionId        Int?                  @map("medical_question")
  changeMedicineQuestionId Int?                  @map("change_medicine_question")
  status                   Boolean               @default(true)
  createdAt                DateTime?             @map("created_at") @db.Timestamp(0)
  updatedAt                DateTime?             @map("updated_at") @db.Timestamp(0)
  metaTitle                String?               @map("meta_title") @db.VarChar(255)
  metaDescription          String?               @map("meta_description") @db.Text
  metaKeywords             String?               @map("meta_keywords") @db.VarChar(255)
  ogImage                  String?               @map("og_image") @db.VarChar(255)
  swappableCampaignId      Int?                  @map("swappable_campaign_id")
  renewalCampaignId        Int?                  @map("renewal_campaign_id")
  createdBy                Int?                  @map("created_by")
  updatedBy                Int?                  @map("updated_by")
  deletedBy                Int?                  @map("deleted_by")
  deletedAt                DateTime?             @map("deleted_at") @db.Timestamp(0)
  genericQuestion          Questionnaire?        @relation("ProductGeneralQuestion", fields: [genericQuestionId], references: [id], map: "products_generic_question_fk")
  medicalQuestion          Questionnaire?        @relation("ProductMedicalQuestion", fields: [medicalQuestionId], references: [id], map: "products_medical_question_id_fk")
  changeMedicineQuestion   Questionnaire?        @relation("ProductChangeMedicineQuestion", fields: [changeMedicineQuestionId], references: [id], map: "products_change_medicine_question_fk")
  swappableCampaign        CrmCampaign?          @relation("ProductSwappableCampaign", fields: [swappableCampaignId], references: [id], map: "products_swappable_campaign_id_fk")
  renewalCampaign          CrmCampaign?          @relation("ProductRenewalCampaign", fields: [renewalCampaignId], references: [id], map: "products_renewal_campaign_id_fk")
  variants                 ProductVariant[]
  swappableProducts        SwappableProduct[]    @relation("ProductSwappableSource")
  swappableBy              SwappableProduct[]    @relation("ProductSwappableTarget")
  relatedItems             ProductRelatedItem[]  @relation("RelatedProduct")
  usedAsAdditional         ProductRelatedItem[]  @relation("AdditionalProduct")
  funnelProducts           FunnelProduct[]
  planVariantPrices        PlanVariantPrice[]

  @@index([changeMedicineQuestionId], map: "products_change_medicine_question_fk")
  @@index([genericQuestionId], map: "products_generic_question_fk")
  @@index([medicalQuestionId], map: "products_medical_question_id_fk")
  @@index([renewalCampaignId], map: "products_renewal_campaign_id_fk")
  @@index([status], map: "products_status_index")
  @@index([swappableCampaignId], map: "products_swappable_campaign_id_fk")
  @@index([productSlugName], map: "products_product_slug_name_index")
  @@map("products")
}

model ProductVariant {
  id                         Int              @id @default(autoincrement())
  title                      String           @db.VarChar(255)
  variantName                String           @map("variant_name") @db.VarChar(255)
  productId                  Int              @map("product_id")
  crmOfferId                 Int?             @map("crm_offer_id")
  doctorNetworkId            Int?             @map("doctor_network_id")
  docNetworkOfferingId       String           @map("doc_network_offering_id") @db.VarChar(100)
  isSupplyAvailable          Boolean          @map("is_supply_available") @default(false)
  isTitrationAvailable       Boolean          @map("is_titration_available") @default(false)
  description                String?          @db.Text
  image                      String?          @db.VarChar(255)
  gender                     ProductGender    @default(both)
  crmItem                    String?          @map("crm_item") @db.VarChar(255)
  shippingProfileId          Int?             @map("shipping_profile")
  pharmacy                   String?          @db.VarChar(255)
  crmCampaignId              Int?             @map("crm_campaign_id")
  doctorQuantity             Int              @map("doctor_quantity") @default(0)
  doctorPrescriptionDuration Int              @map("doctor_prescription_duration") @default(0)
  sellingPrice               Decimal          @map("selling_price") @default(0.00) @db.Decimal(10, 2)
  refills                    Int              @default(0)
  daysSupplies               Int              @map("days_supplies") @default(0)
  dispenseUnits              Int              @map("dispense_units") @default(0)
  isPopular                  Boolean          @map("is_popular") @default(false)
  status                     Boolean          @default(true)
  variantOrder               Int              @map("variant_order") @default(1) @db.TinyInt
  blockArmedMilitary         Boolean          @map("block_armed_military") @default(false)
  blockIslandTerritories     Boolean          @map("block_island_territories") @default(false)
  createdAt                  DateTime?        @map("created_at") @db.Timestamp(0)
  updatedAt                  DateTime?        @map("updated_at") @db.Timestamp(0)
  deletedAt                  DateTime?        @map("deleted_at") @db.Timestamp(0)
  product                    Product          @relation(fields: [productId], references: [id], map: "product_variants_product_id_fk")
  crmOffer                   CrmOffer?        @relation(fields: [crmOfferId], references: [id], map: "product_variants_crm_offer_id_fk")
  doctorNetwork              DoctorNetwork?   @relation(fields: [doctorNetworkId], references: [id], map: "product_variants_doctor_network_id_fk")
  crmCampaign                CrmCampaign?     @relation(fields: [crmCampaignId], references: [id], map: "product_variants_crm_campaign_id_fk")
  shippingProfile            CrmShipping?     @relation(fields: [shippingProfileId], references: [id], map: "product_variants_shipping_profile_fk")
  funnelProducts             FunnelProduct[]
  orderItems                 OrderItem[]
  relatedItems               ProductRelatedItem[]
  planVariantPrices          PlanVariantPrice[]

  @@index([crmCampaignId], map: "product_variants_crm_campaign_id_fk")
  @@index([crmOfferId], map: "product_variants_crm_offer_id_fk")
  @@index([docNetworkOfferingId], map: "product_variants_doc_network_offering_id_index")
  @@index([doctorNetworkId], map: "product_variants_doctor_network_id_fk")
  @@index([isPopular], map: "product_variants_is_popular_index")
  @@index([productId], map: "product_variants_product_id_fk")
  @@index([shippingProfileId], map: "product_variants_shipping_profile_fk")
  @@index([status], map: "product_variants_status_index")
  @@map("product_variants")
}

model SwappableProduct {
  id                Int       @id @default(autoincrement())
  productId         Int       @map("product_id")
  swapableProductId Int       @map("swapable_product_id")
  createdAt         DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt         DateTime? @map("updated_at") @db.Timestamp(0)
  product           Product   @relation("ProductSwappableSource", fields: [productId], references: [id], map: "swapable_products_product_id_foreign")
  swapableProduct   Product   @relation("ProductSwappableTarget", fields: [swapableProductId], references: [id], map: "swapable_products_swapable_product_id_foreign")

  @@unique([productId, swapableProductId])
  @@index([productId], map: "swapable_products_product_id_foreign")
  @@index([swapableProductId], map: "swapable_products_swapable_product_id_foreign")
  @@map("swapable_products")
}

model ProductRelatedItem {
  id                  Int             @id @default(autoincrement())
  productId           Int             @map("product_id")
  variantId           Int?            @map("variant_id")
  type                RelatedItemType
  additionalProductId Int             @map("additional_product_id")
  createdAt           DateTime?       @map("created_at") @db.Timestamp(0)
  updatedAt           DateTime?       @map("updated_at") @db.Timestamp(0)
  product             Product         @relation("RelatedProduct", fields: [productId], references: [id], map: "product_related_items_product_id_foreign")
  variant             ProductVariant? @relation(fields: [variantId], references: [id], map: "product_related_items_variant_id_foreign")
  additionalProduct   Product         @relation("AdditionalProduct", fields: [additionalProductId], references: [id], map: "product_related_items_additional_product_id_foreign")

  @@unique([productId, variantId, additionalProductId, type])
  @@index([additionalProductId], map: "product_related_items_additional_product_id_foreign")
  @@index([productId], map: "product_related_items_product_id_foreign")
  @@index([variantId], map: "product_related_items_variant_id_foreign")
  @@map("product_related_items")
}

model Dataset {
  id        Int       @id @default(autoincrement())
  name      String    @db.VarChar(191)
  label     String    @db.VarChar(191)
  type      String    @db.VarChar(191)
  canDelete Boolean   @map("can_delete") @default(true)
  createdAt DateTime? @map("created_at") @db.Timestamp(0)
  updatedAt DateTime? @map("updated_at") @db.Timestamp(0)

  @@index([type], map: "datasets_type_index")
  @@map("datasets")
}

model SubscriptionPlan {
  id                Int                @id @default(autoincrement())
  name              String             @db.VarChar(255)
  description       String             @db.Text
  duration          Int?
  status            String             @db.VarChar(1)
  createdAt         DateTime?          @map("created_at") @db.Timestamp(0)
  updatedAt         DateTime?          @map("updated_at") @db.Timestamp(0)
  planVariantPrices PlanVariantPrice[]

  @@index([status], map: "subscription_plans_status_index")
  @@map("subscription_plans")
}

model PlanVariantPrice {
  id               Int              @id @default(autoincrement())
  planId           Int              @map("plan_id")
  productId        Int?             @map("product_id")
  productVariantId Int              @map("product_variant_id")
  crmCampaignId    Int              @map("crm_campaign_id")
  shippingProfile  Int              @map("shipping_profile")
  crmOfferId       Int              @map("crm_offer_id")
  durationWeeks    Int              @map("duration_weeks")
  supplyWeeks      Int              @map("supply_weeks")
  originalPrice    Decimal          @map("original_price") @default(0.00) @db.Decimal(10, 2)
  discountAmount   Decimal          @map("discount_amount") @default(0.00) @db.Decimal(10, 2)
  discountCoupon   String?          @map("discount_coupon") @db.VarChar(100)
  isDefault        Boolean          @map("is_default") @default(false)
  status           Boolean          @default(true)
  createdAt        DateTime?        @map("created_at") @db.Timestamp(0)
  updatedAt        DateTime?        @map("updated_at") @db.Timestamp(0)
  subscriptionPlan SubscriptionPlan @relation(fields: [planId], references: [id], map: "plan_variant_prices_plan_id_foreign")
  product          Product?         @relation(fields: [productId], references: [id], map: "plan_variant_prices_product_id_foreign")
  productVariant   ProductVariant   @relation(fields: [productVariantId], references: [id], map: "plan_variant_prices_product_variant_id_foreign")
  crmCampaign      CrmCampaign      @relation(fields: [crmCampaignId], references: [id], map: "plan_variant_prices_crm_campaign_id_foreign")
  crmOffer         CrmOffer         @relation(fields: [crmOfferId], references: [id], map: "plan_variant_prices_crm_offer_id_foreign")
  crmShipping      CrmShipping      @relation(fields: [shippingProfile], references: [id], map: "plan_variant_prices_shipping_profile_foreign")

  @@index([planId], map: "plan_variant_prices_plan_id_index")
  @@index([productId], map: "plan_variant_prices_product_id_index")
  @@index([productVariantId], map: "plan_variant_prices_product_variant_id_index")
  @@index([crmCampaignId], map: "plan_variant_prices_crm_campaign_id_index")
  @@index([crmOfferId], map: "plan_variant_prices_crm_offer_id_index")
  @@index([shippingProfile], map: "plan_variant_prices_shipping_profile_index")
  @@map("plan_variant_prices")
}

model Funnel {
  id                  Int             @id @default(autoincrement())
  funnelName          String          @map("funnel_name") @db.VarChar(255)
  crmCampaignId       Int             @map("crm_campaign_id")
  swappableCampaignId Int?            @map("swappable_campaign_id")
  renewalCampaignId   Int?            @map("renewal_campaign_id")
  displayDefault      Boolean         @map("display_default") @default(false)
  slug                String          @db.VarChar(255)
  image               String?         @db.VarChar(255)
  description         String?         @db.VarChar(255)
  shortDescription    String?         @map("short_description") @db.VarChar(255)
  redirectType        RedirectType    @map("redirect_type") @default(soft)
  redirectFunnelId    Int?            @map("redirect_funnel_id")
  promoSlug           String?         @map("promo_slug") @db.VarChar(255)
  createdAt           DateTime?       @map("created_at") @db.Timestamp(0)
  updatedAt           DateTime?       @map("updated_at") @db.Timestamp(0)
  status              Boolean         @default(true)
  metaTitle           String?         @map("meta_title") @db.VarChar(255)
  metaDescription     String?         @map("meta_description") @db.Text
  metaKeywords        String?         @map("meta_keywords") @db.VarChar(255)
  ogImage             String?         @map("og_image") @db.VarChar(255)
  template            String          @default("default") @db.VarChar(255)
  createdBy           Int?            @map("created_by")
  updatedBy           Int?            @map("updated_by")
  deletedBy           Int?            @map("deleted_by")
  deletedAt           DateTime?       @map("deleted_at") @db.Timestamp(0)
  crmCampaign         CrmCampaign     @relation("FunnelCampaign", fields: [crmCampaignId], references: [id], map: "funnels_crm_campaign_id_fk")
  swappableCampaign   CrmCampaign?    @relation("FunnelSwappableCampaign", fields: [swappableCampaignId], references: [id], map: "funnels_swappable_campaign_id_fk")
  renewalCampaign     CrmCampaign?    @relation("FunnelRenewalCampaign", fields: [renewalCampaignId], references: [id], map: "funnels_renewal_campaign_id_fk")
  redirectFunnel      Funnel?         @relation("FunnelRedirect", fields: [redirectFunnelId], references: [id], map: "funnels_redirect_funnel_id_foreign")
  redirectedFunnels   Funnel[]        @relation("FunnelRedirect")
  funnelProducts      FunnelProduct[]
  orders              Order[]

  @@unique([slug, deletedAt], map: "funnels_slug_unique")
  @@unique([slug, promoSlug], map: "unique_slug_promo_slug")
  @@index([crmCampaignId], map: "funnels_crm_campaign_id_fk")
  @@index([displayDefault], map: "funnels_display_default_index")
  @@index([promoSlug], map: "funnels_promo_slug_index")
  @@index([redirectFunnelId], map: "funnels_redirect_funnel_id_foreign")
  @@index([renewalCampaignId], map: "funnels_renewal_campaign_id_fk")
  @@index([status], map: "funnels_status_index")
  @@index([swappableCampaignId], map: "funnels_swappable_campaign_id_fk")
  @@index([template], map: "funnels_template_index")
  @@map("funnels")
}

model FunnelProduct {
  id                      Int             @id @default(autoincrement())
  funnelId                Int             @map("funnel_id")
  productId               Int             @map("product_id")
  crmCampaignId           Int             @map("crm_campaign_id")
  defaultProductVariantId Int?            @map("default_product_variant_id")
  createdAt               DateTime?       @map("created_at") @db.Timestamp(0)
  updatedAt               DateTime?       @map("updated_at") @db.Timestamp(0)
  status                  Boolean         @default(true)
  createdBy               Int?            @map("created_by")
  updatedBy               Int?            @map("updated_by")
  deletedBy               Int?            @map("deleted_by")
  deletedAt               DateTime?       @map("deleted_at") @db.Timestamp(0)
